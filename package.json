{
  "name": "convergo",
  "version": "0.1.0",
  "description": "Fresh-reviewer convergence workflow skills for coding agents",
  "type": "module",
  "private": true,
  "main": ".opencode/plugins/convergo.js",
  "pi": {
    "extensions": [
      "./.pi/extensions/convergo.ts"
    ],
    "skills": [
      "./plugins/generic/skills"
    ]
  },
  "homepage": "https://github.com/gomilesf/convergo",
  "repository": "https://github.com/gomilesf/convergo",
  "license": "MIT",
  "keywords": [
    "ai",
    "agent-skills",
    "codex",
    "claude-code",
    "compound-engineering",
    "fresh-reviewer",
    "workflow-automation"
  ],
  "scripts": {
    "sync": "bun run scripts/sync-platform-skills.ts",
    "validate": "bun run scripts/validate.ts",
    "install:codex-agents": "bun run scripts/install-codex-agents.ts",
    "plugin:validate": "claude plugin validate .claude-plugin/marketplace.json && claude plugin validate plugins/claude",
    "test": "bun test"
  },
  "devDependencies": {
    "bun-types": "^1.0.0"
  }
}
